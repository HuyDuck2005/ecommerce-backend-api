<div class="container py-5">
  <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4">
    <div class="mb-3 mb-md-0">
      <h1 class="h3 fw-bold text-dark mb-2">
        <i class="fas fa-graduation-cap text-primary me-2"></i>
        All Courses
      </h1>
      <p class="text-muted mb-0">Browse and explore our collection of courses</p>
    </div>
    <a href="/courses/create" class="btn btn-primary d-inline-flex align-items-center gap-2 shadow-sm">
      <i class="fas fa-plus-circle"></i>
      <span>Create New Course</span>
    </a>
  </div>

  {{#if courses}}
    {{#each courses}}
    <div class="card mb-4 border-0 shadow-sm">
      <div class="row g-0">
        <div class="col-md-4">
          <div class="position-relative h-100">
            <img src="{{this.image_url}}" class="img-fluid w-100 h-100 object-fit-cover rounded-start" alt="{{this.title}}">
          </div>
        </div>
        <div class="col-md-8">
          <div class="card-body d-flex flex-column h-100">
            <div>
              <h2 class="card-title h5 fw-bold text-dark mb-2">{{this.title}}</h2>
              <p class="card-text text-muted mb-2">{{this.description}}</p>
              <p class="card-text mb-2">
                <small class="text-body-secondary">{{this.instructor_name}}</small>
              </p>

              <div class="d-flex align-items-center gap-2 mb-2">
                <span class="fw-bold text-warning">{{this.rating}}</span>
                <div class="d-flex text-warning">
                  {{{renderStars this.rating}}}
                </div>
                <span class="text-muted small">({{this.total_reviews}})</span>
              </div>

              <ul class="list-inline small text-muted mb-0">
                <li class="list-inline-item">{{this.total_hours}} total hours</li>
                <li class="list-inline-item">•</li>
                <li class="list-inline-item">{{this.total_lectures}} lectures</li>
                <li class="list-inline-item">•</li>
                <li class="list-inline-item">{{this.level}}</li>
              </ul>
              {{#if this.isBestseller}}
                <div class="mt-2">
                   <span class="badge bg-warning text-dark text-uppercase fw-semibold px-3 py-2">Bestseller</span>
                </div>
              {{/if}}
            </div>

            <div class="mt-3 d-flex justify-content-end align-items-baseline gap-2">
              <span class="fw-bold fs-4 text-dark">{{this.formatted_current_price}}</span>
              <span class="fs-6 text-muted text-decoration-line-through">{{this.formatted_original_price}}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
    {{/each}}
  {{else}}
    <div class="alert alert-info">Chưa có khóa học nào trong CSDL.</div>
  {{/if}}
</div>